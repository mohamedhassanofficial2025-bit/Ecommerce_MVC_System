@{
    ViewData["Title"] = "Dashboard Overview";
}

<style>
    /* Dashboard Content Specific Scopes */
    .dashboard-welcome-header {
        margin-bottom: 40px;
        animation: fadeIn 0.4s ease-out;
    }

    .dashboard-title {
        font-size: 1.85rem;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.03em;
    }

    .dashboard-subtitle {
        font-size: 0.95rem;
        color: #64748b;
        margin-top: 4px;
    }

    /* Premium Management Card Grid Matrix */
    .management-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 24px;
        width: 100%;
        animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .premium-management-card {
        background-color: #ffffff;
        border: 1px solid #f1f5f9;
        border-radius: 16px;
        padding: 32px;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.02), 0 1px 2px -1px rgba(0, 0, 0, 0.02);
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .premium-management-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(800px circle at var(--mouse-x, 0) var(--mouse-y, 0), rgba(15, 23, 42, 0.03), transparent 40%);
        z-index: 1;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .premium-management-card:hover::before {
        opacity: 1;
    }

    .premium-management-card:hover {
        transform: translateY(-4px);
        border-color: #e2e8f0;
        box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.04), 0 8px 10px -6px rgba(15, 23, 42, 0.04);
    }

    .card-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 24px;
        font-size: 1.35rem;
        transition: var(--transition-smooth);
    }

    /* Context Color Mappings */
    .card-icon-category {
        background-color: #f0fdf4;
        color: #16a34a;
    }
    
    .card-icon-product {
        background-color: #fef2f2;
        color: #dc2626;
    }

    .premium-management-card:hover .card-icon-wrapper {
        transform: scale(1.05);
    }

    .card-meta-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #0f172a;
        letter-spacing: -0.015em;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .card-meta-desc {
        font-size: 0.875rem;
        color: #64748b;
        line-height: 1.5;
        margin-bottom: 24px;
    }

    .card-action-trigger {
        font-size: 0.875rem;
        font-weight: 600;
        color: #0f172a;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s ease;
    }

    .premium-management-card:hover .card-action-trigger {
        color: #2563eb;
    }

    .premium-management-card:hover .card-action-trigger i {
        transform: translateX(4px);
    }

    .card-action-trigger i {
        transition: transform 0.2s ease;
        font-size: 0.75rem;
    }

    /* Core Microkeyframes Animations */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 0; transform: translateY(0); }
    }
</style>

<div class="dashboard-welcome-header">
    <h1 class="dashboard-title">System Overview</h1>
    <p class="dashboard-subtitle">Manage store definitions, monitor inventory indices, and navigate backend parameters.</p>
</div>

<div class="management-grid" id="cardMatrix">
    
    <a href="~/Category/index" class="premium-management-card">
        <div>
            <div class="card-icon-wrapper card-icon-category">
                <i class="bi bi-folder2-open"></i>
            </div>
            <h2 class="card-meta-title">Categories Portal</h2>
            <p class="card-meta-desc">Structure warehouse classifications, arrange hierarchical metadata, and monitor catalogs.</p>
        </div>
        <div class="card-action-trigger">
            <span>Open Dashboard</span>
            <i class="bi bi-arrow-right"></i>
        </div>
    </a>

    <a href="~/Product/index" class="premium-management-card">
        <div>
            <div class="card-icon-wrapper card-icon-product">
                <i class="bi bi-box-seam-fill"></i>
            </div>
            <h2 class="card-meta-title">Products Portal</h2>
            <p class="card-meta-desc">Modify variant specifications, audit SKU availability status tracking records, and update pricing listings.</p>
        </div>
        <div class="card-action-trigger">
            <span>Open Dashboard</span>
            <i class="bi bi-arrow-right"></i>
        </div>
    </a>

</div>

@section Scripts {
    <script>
        // Interactive Mouse-Tracking Gradient Mask Reflection (Stripe/Linear Inspired)
        document.addEventListener('DOMContentLoaded', function() {
            const cards = document.querySelectorAll('.premium-management-card');
            
            cards.forEach(card => {
                card.addEventListener('mousemove', function(e) {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    
                    card.style.setProperty('--mouse-x', `${x}px`);
                    card.style.setProperty('--mouse-y', `${y}px`);
                });
            });
        });
    </script>
}