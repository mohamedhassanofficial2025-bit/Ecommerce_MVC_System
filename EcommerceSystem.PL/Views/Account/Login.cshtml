@using EcommerceSystem.PL.ViewModels.Auth
@model LoginVM

@{
    ViewData["Title"] = "Account Identity Authorization Phase";
}

<style>
    .login-card-canvas {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        animation: authFrameSlideIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .login-banner-header {
        background-color: #0f172a;
        color: #ffffff;
        padding: 40px 32px;
    }

    .login-form-control {
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 0.95rem;
        transition: all 0.2s ease-in-out;
    }

        .login-form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }

    .login-input-icon-group {
        position: relative;
    }

        .login-input-icon-group i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
            pointer-events: none;
        }

        .login-input-icon-group .login-form-control {
            padding-left: 48px;
        }
</style>

<div class="container-fluid px-4 py-5 mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8">
            
            <div class="login-card-canvas">
                <div class="login-banner-header text-center border-0">
                    <h2 class="fw-black tracking-tight mb-2">Welcome Back</h2>
                    <p class="mb-0 text-white-50 fs-6">Submit authorization credentials to verify system scope membership permissions.</p>
                </div>

                <div class="card-body p-4 p-sm-5 bg-white">
                    
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 mb-4 fs-7 shadow-sm"></div>
                    }

                    <form asp-action="Login" asp-controller="Account" asp-antiforgery="true" method="post" class="needs-validation">
                        
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold text-dark fs-7 text-uppercase tracking-wider">Email Address</label>
                            <div class="login-input-icon-group">
                                <i class="bi bi-envelope"></i>
                                <input asp-for="Email" type="email" class="form-control login-form-control" placeholder="name@example.com" autocomplete="username" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger fs-8 mt-1 d-block fw-semibold"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold text-dark fs-7 text-uppercase tracking-wider">Security Key Phrase</label>
                            <div class="login-input-icon-group">
                                <i class="bi bi-lock"></i>
                                <input asp-for="Password" type="password" class="form-control login-form-control" placeholder="••••••••••••" autocomplete="current-password" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger fs-8 mt-1 d-block fw-semibold"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                            <div class="form-check align-items-center d-flex gap-1 m-0">
                                <input asp-for="RememberMe" class="form-check-input mt-0" />
                                <label asp-for="RememberMe" class="form-check-label fs-7 text-muted">Keep Session Alive</label>
                            </div>
                            <a href="#" class="text-primary text-decoration-none small fw-bold fs-7">
                                Recover Security Key?
                            </a>
                        </div>

                        <div class="d-grid mb-4">
                            <button type="submit" class="btn btn-premium-primary btn-lg py-3 fs-6 fw-bold rounded-3 shadow-sm">
                                Authorize Session Identity
                            </button>
                        </div>

                        <div class="text-center pt-2 border-top border-light-subtle">
                            <span class="text-muted fs-7">Deficient active system access accounts?</span>
                            <a asp-action="Register" asp-controller="Account" class="text-primary text-decoration-none fw-bold fs-7 ms-1">
                                Provision Profile Node
                            </a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}