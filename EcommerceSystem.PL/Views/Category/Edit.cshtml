@model CategoryEditVM

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-5 col-md-7">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- Header -->
                <div class="bg-primary text-white text-center py-4">
                    <h4 class="mb-0 fw-bold">Create New Category</h4>
                    <small class="opacity-75">Organize your products easily</small>
                </div>

                <!-- Body -->
                <div class="card-body p-4">

                    @using (Html.BeginForm("Edit", "Category", FormMethod.Post))
                    {
                        <div class="mb-4">

                            @Html.LabelFor(c => c.Name, new { @class = "form-label fw-semibold" })

                            @Html.HiddenFor(c => c.Id)

                            @Html.TextBoxFor(c => c.Name, new
                            {
                                @class = "form-control form-control-lg shadow-sm",
                                placeholder = "e.g. Electronics, Clothing...",
                                required = "required"
                            })

                            @Html.ValidationMessageFor(c => c.Name, "", new { @class = "text-danger" })

                            <small class="text-muted">
                                Choose a clear and unique category name
                            </small>

                        </div>

                        <div class="d-flex justify-content-between align-items-center">

                            @Html.ActionLink("Cancel", "Index", "Category", null, new
                            {
                                @class = "btn btn-outline-secondary px-4"
                            })

                            <button type="submit"
                                    class="btn btn-primary px-4 shadow-sm">
                                + Save Changes
                            </button>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>