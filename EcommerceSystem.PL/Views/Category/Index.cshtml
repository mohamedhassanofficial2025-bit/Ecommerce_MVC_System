@model List<CategoryReadVM>

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-primary">Categories Dashboard</h2>
            <small class="text-muted">Organize your product catalog</small>
        </div>

        <div class="d-flex gap-2">

            <a href="/Home/Index" class="btn btn-outline-dark">
                🏠 Home
            </a>

            @if(User.IsInRole("Admin"))
            {
                <a href="/Category/Create" class="btn btn-success px-4">
                    + Add Category
                </a>

            }
            )
        </div>

    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="bg-dark text-white">
                        <tr>
                            <th>#</th>
                            <th>Category</th>
                            <th>Products</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var c in Model)
                        {
                            <tr>

                                <td>@c.Id</td>

                                <td class="fw-semibold">
                                    @c.Name
                                </td>

                                <td>
                                    <span class="badge bg-info text-dark px-3 py-2">
                                        @c.NoProductTypes
                                    </span>
                                </td>

                                <td class="text-center">

                                    <a href="/Category/Details/@c.Id"
                                           class="btn btn-sm btn-outline-info">
                                        View
                                    </a>

                                    @if(User.IsInRole("Admin"))
                                    {
                                        <a href="/Category/Edit/@c.Id"
                                               class="btn btn-sm btn-outline-warning">
                                            Edit
                                        </a>

                                        <button class="btn btn-sm btn-outline-danger deleteBtn"
                                                data-id="@c.Id"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal">
                                            Delete
                                        </button>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- ✅ Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content rounded-4">

            <div class="modal-header">
                <h5 class="modal-title text-danger">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <p class="mb-0">Are you sure you want to delete this category?</p>
            </div>

            <div class="modal-footer justify-content-center">

                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <a id="confirmDeleteBtn" class="btn btn-danger">
                    Delete
                </a>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        const deleteButtons = document.querySelectorAll(".deleteBtn");
        const confirmBtn = document.getElementById("confirmDeleteBtn");

        deleteButtons.forEach(btn => {
            btn.addEventListener("click", function () {
                const id = this.getAttribute("data-id");
                confirmBtn.href = `/Category/Delete/${id}`;
            });
        });

    </script>

}