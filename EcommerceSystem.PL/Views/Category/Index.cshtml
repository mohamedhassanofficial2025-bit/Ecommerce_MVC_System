@model List<CategoryReadVM>

@{
    ViewData["Title"] = "Structural Catalog Categories";
}

<style>
    .category-card-canvas {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -2px rgba(0, 0, 0, 0.02);
        overflow: hidden;
        animation: cardFadeIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .category-table thead {
        background-color: #0f172a;
        color: #ffffff;
    }

    .category-table th {
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 18px 24px;
        border: none;
    }

    .category-table td {
        padding: 16px 24px;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
    }

    .metric-badge {
        font-weight: 600;
        font-size: 0.8rem;
        padding: 6px 14px;
        border-radius: 6px;
    }

    @@keyframes cardFadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="container-fluid px-4 py-4">
    
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-sm-items-center gap-3 mb-4">
        <div>
            <h1 class="h2 fw-bold text-dark m-0">Category Architecture</h1>
            <p class="text-muted m-0 fs-7">Structure high-level inventory taxonomy nodes and monitor relational density indices.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" asp-controller="Home" class="btn btn-premium-outline">
                <i class="bi bi-house-door me-1"></i> Home
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" asp-controller="Category" class="btn btn-premium-primary">
                    <i class="bi bi-plus-lg me-1"></i> Add New Category
                </a>
            }
        </div>
    </div>

    <div class="category-card-canvas">
        <div class="table-responsive">
            <table class="table category-table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 100px;">Index</th>
                        <th>Classification node designation</th>
                        <th style="width: 260px;">Associated SKU density</th>
                        <th class="text-end" style="width: 240px;">Control actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="text-muted fw-mono fs-7">#@c.Id</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="text-primary"><i class="bi bi-folder2-open fs-5"></i></div>
                                    <span class="fw-bold text-dark fs-6">@c.Name</span>
                                </div>
                            </td>
                            <td>
                                <span class="metric-badge bg-primary-subtle text-primary">
                                    <i class="bi bi-tag-fill me-1"></i> @c.NoProductTypes Assigned Types
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Details" asp-controller="Category" asp-route-id="@c.Id" class="btn btn-sm btn-premium-outline px-3">
                                        View
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-controller="Category" asp-route-id="@c.Id" class="btn btn-sm btn-premium-outline px-3 text-warning">
                                            Edit
                                        </a>
                                        <button class="btn btn-sm btn-premium-danger px-3 deleteBtn"
                                                data-id="@c.Id"
                                                data-name="@c.Name"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal">
                                            Delete
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-premium rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-danger d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i> Drop Classification Segment
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-2">
                <p class="text-muted m-0">Dropping this catalog partition node could leave assigned downstream items without a category assignment map. Please check your inventory density before proceeding.</p>
                <div class="p-3 bg-light rounded-3 mt-3 border border-light-subtle">
                    <span class="fs-8 text-muted d-block text-uppercase fw-bold tracking-wider">Target Domain Name</span>
                    <h5 class="fw-bold text-dark m-0 mt-1" id="categoryNameField"></h5>
                </div>
            </div>
            <div class="modal-footer border-0 pb-4 px-4 justify-content-end gap-2">
                <button type="button" class="btn btn-premium-outline" data-bs-dismiss="modal">Cancel De-allocation</button>
                <a id="confirmDeleteBtn" class="btn btn-danger px-4 text-white border-0">Execute Drop</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const deleteButtons = document.querySelectorAll(".deleteBtn");
            const confirmBtn = document.getElementById("confirmDeleteBtn");
            const categoryNameField = document.getElementById("categoryNameField");

            deleteButtons.forEach(btn => {
                btn.addEventListener("click", function () {
                    const id = this.getAttribute("data-id");
                    const name = this.getAttribute("data-name");

                    categoryNameField.innerText = name;
                    confirmBtn.href = `/Category/Delete/${id}`;
                });
            });
        });
    </script>
}