@model CategoryCreateVM

@{
    ViewData["Title"] = "Provision Classification Node";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8 col-md-10">
            
            <div class="card border-0 shadow-premium rounded-4 overflow-hidden bg-white">
                <div class="bg-success text-white p-4 border-0">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white text-success rounded-3 px-3 py-2 fw-bold">
                            <i class="bi bi-folder-plus"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">Provision New Category</h4>
                            <p class="text-white-50 m-0 fs-7">Publish a new catalog organization scope definition module.</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 pt-5">
                    <form asp-action="Create" asp-controller="Category" asp-antiforgery="true" method="post" class="needs-validation">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-dark fs-7 text-uppercase">Category Designation Title</label>
                            <input asp-for="Name" class="form-control form-control-lg border-light-subtle fs-6 shadow-sm" placeholder="e.g. Electronics, Medical Hardware, Wearables..." />
                            <span asp-validation-for="Name" class="text-danger fs-7 mt-1 d-block"></span>
                            <small class="text-muted d-block mt-2 fs-8">Provide an individual nomenclature parameter distinct from existing inventory grouping nodes.</small>
                        </div>

                        <div class="d-flex justify-content-between align-items-center border-top border-light-subtle pt-4 mt-5">
                            <a asp-action="Index" asp-controller="Category" class="btn btn-premium-outline px-4">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-success text-white border-0 px-4 fw-bold shadow-sm">
                                <i class="bi bi-check-circle-fill me-1"></i> Deploy Taxonomy Node
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}