@model CategoryReadVM

@{
    ViewData["Title"] = $"Category Workspace - {Model.Name}";
}

<style>
    .identity-profile-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -2px rgba(0, 0, 0, 0.02);
    }

    .preview-table-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -2px rgba(0, 0, 0, 0.02);
        overflow: hidden;
    }

    .custom-nested-table thead {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .custom-nested-table th {
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        padding: 14px 24px;
    }

    .custom-nested-table td {
        padding: 16px 24px;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
    }

    .interactive-row-target {
        transition: background-color 0.2s ease;
    }

        .interactive-row-target:hover {
            background-color: #f8fafc;
        }
</style>

<div class="container-fluid px-4 py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12">
            
            <div class="card border-0 identity-profile-card p-4 mb-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary-subtle text-primary rounded-3 px-3 py-3 fs-3">
                            <i class="bi bi-folder-fill"></i>
                        </div>
                        <div>
                            <span class="text-muted fs-8 text-uppercase tracking-wider fw-bold">Classification Node Root</span>
                            <h2 class="fw-extrabold text-dark m-0 mt-1">@Model.Name</h2>
                            <small class="text-muted fw-mono d-block mt-1">System Trace Registry: #@Model.Id</small>
                        </div>
                    </div>
                    
                    <div class="bg-light border border-light-subtle rounded-4 p-3 text-center text-md-end min-w-md-160">
                        <span class="fs-8 text-muted text-uppercase tracking-wider fw-semibold d-block">Downstream Profiles</span>
                        <h3 class="fw-black text-primary m-0 mt-1">
                            @(Model.NoProductTypes == 0 && Model.Products != null ? Model.Products.Count : Model.NoProductTypes)
                        </h3>
                    </div>
                </div>
            </div>

            <div class="card border-0 preview-table-card mb-4">
                <div class="card-header bg-dark p-4 border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h5 class="text-white m-0 fw-bold">Downstream Products Preview</h5>
                        <p class="text-white-50 m-0 fs-8">Displays up to five products currently mapped to this tracking domain.</p>
                    </div>
                    
                    @* Fixed User Mode Privilege Bug: Hidden completely from standard consumer sessions *@
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="d-flex gap-2">
                            <a href="/Product/Create?categoryId=@Model.Id" class="btn btn-sm btn-success text-white border-0 px-3 fw-medium">
                                <i class="bi bi-plus-circle me-1"></i> Append Product
                            </a>
                            <a href="/Product/Index?categoryId=@Model.Id" class="btn btn-sm btn-outline-light px-3">
                                <i class="bi bi-eye-fill me-1"></i> View Full Collection
                            </a>
                        </div>
                    }
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 custom-nested-table">
                            <thead>
                                <tr>
                                    <th style="width: 100px;">Asset ID</th>
                                    <th>Product Title Matrix</th>
                                    <th>Market Valuation</th>
                                    <th style="width: 180px;">Inventory Volume</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Products == null || !Model.Products.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <div class="fs-3 opacity-50 mb-2"><i class="bi bi-inbox"></i></div>
                                            <p class="m-0 fs-7">No active product records mapped to this segment configuration profiles.</p>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var p in Model.Products.Take(5))
                                    {
                                        <tr onclick="location.href='/Product/Details/@p.Id'" style="cursor:pointer;" class="interactive-row-target">
                                            <td class="fw-mono text-muted fs-7">#@p.Id</td>
                                            <td class="fw-semibold text-dark">@p.Title</td>
                                            <td>
                                                <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                                    $@p.Price.ToString("F2")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @(p.Count > 5 ? "bg-primary-subtle text-primary" : "bg-danger-subtle text-danger") px-3 py-2 w-100 text-start d-flex justify-content-between align-items-center">
                                                    <span>@p.Count Units</span>
                                                    <i class="bi bi-circle-fill" style="font-size: 6px;"></i>
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <a asp-action="Index" asp-controller="Category" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left me-1"></i> Return to Category Grid
                </a>
                
                @if (User.IsInRole("Admin"))
                {
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-controller="Category" asp-route-id="@Model.Id" class="btn btn-outline-warning px-4">
                            <i class="bi bi-pencil-square me-1"></i> Edit Definition
                        </a>
                        <button class="btn btn-outline-danger px-4" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="@Model.Id" data-name="@Model.Name">
                            <i class="bi bi-trash3-fill me-1"></i> Drop Component
                        </button>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-body p-5 text-center">
                    <div class="bg-danger-subtle text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 80px; height: 80px;">
                        <i class="bi bi-trash3-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-2">Delete Classification Node?</h4>
                    <p class="text-muted px-2 mb-4">You are planning to scrub out this group matrix profile node entirely. Ensure downstream dependency mapping is cleared.</p>
                    <div class="p-3 bg-light rounded-3 text-start border border-light-subtle mb-4">
                        <span class="fs-8 text-muted text-uppercase fw-bold d-block tracking-wider">Target ID Entity</span>
                        <span class="fw-bold text-dark fs-6" id="targetProfileLabel">@Model.Name</span>
                    </div>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Retain Element</button>
                        <button type="button" class="btn btn-danger px-4 text-white border-0" id="executeDropBtn">Confirm Drop Action</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (User.IsInRole("Admin"))
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const executeDropBtn = document.getElementById("executeDropBtn");
                if(executeDropBtn) {
                    executeDropBtn.addEventListener("click", function() {
                        this.innerText = "Executing Drop Operations...";
                        this.disabled = true;
                        window.location.href = `/Category/Delete/@Model.Id`;
                    });
                }
            });
        </script>
    }
}