
@model CategoryReadVM

<div class="container mt-5">

    <!-- ================= Header Info ================= -->
    <div class="card border-0 shadow-lg rounded-4 mb-4 p-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <div>
                <h3 class="fw-bold mb-1">@Model.Name</h3>
                <small class="text-muted">Category ID: #@Model.Id</small>
            </div>

            <div class="text-center mt-3 mt-md-0">
                <h6 class="mb-1 text-muted">Products</h6>
                <span class="badge bg-primary fs-6 px-3 py-2">
                    @Model.NoProductTypes
                </span>
            </div>

        </div>

    </div>

    <!-- ================= Products Preview ================= -->
    <div class="card border-0 shadow-lg rounded-4 mb-4">

        <div class="card-header bg-dark text-white rounded-top-4 d-flex justify-content-between align-items-center">

            <span>Products Preview</span>

            <div class="d-flex gap-2">
                <a href="/Product/Create?categoryId=@Model.Id"
                       class="btn btn-success btn-sm">
                    + Add Product
                </a>

                <a href="/Product/Index?categoryId=@Model.Id"
                       class="btn btn-outline-light btn-sm">
                    View All
                </a>
            </div>

        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Price</th>
                            <th>Stock</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (!Model.Products.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    No products in this category 😢
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var p in Model.Products.Take(5))
                            {
                                <tr onclick="location.href='/Product/Details/@p.Id'" style="cursor:pointer">

                                    <td>@p.Id</td>

                                    <td class="fw-semibold">@p.Title</td>

                                    <td>
                                        <span class="badge bg-success px-3 py-2">
                                            $@p.Price
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge @(p.Count > 5 ? "bg-primary" : "bg-danger") px-3 py-2">
                                            @p.Count
                                        </span>
                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- ================= Actions ================= -->
    <div class="card border-0 shadow-lg rounded-4 p-4">

        <h5 class="mb-3 fw-semibold">Category Actions</h5>

        @if(User.IsInRole("Admin"))
        {
            <div class="d-flex flex-wrap gap-2">

                <a href="/Category/Edit/@Model.Id"
                       class="btn btn-warning">
                    Edit Category
                </a>

                <button class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteModal"
                        data-id="@Model.Id"
                        data-name="@Model.Name">
                    Delete Category
                </button>

            </div>
        }

    </div>

    <!-- ================= Back ================= -->
    <div class="mt-4">
        <a href="/Category/Index" class="btn btn-outline-secondary">
            ← Back to Categories
        </a>
    </div>

</div>

<!-- ================= Delete Modal ================= -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">

            <div class="modal-header border-0">
                <h5 class="modal-title text-danger">Delete Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <p>
                    Are you sure you want to delete<br />
                    <strong class="text-danger fs-5" id="catName"></strong>?
                </p>
            </div>

            <div class="modal-footer border-0 justify-content-center">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger" id="confirmDelete">Delete</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modal = document.getElementById('deleteModal');

        modal.addEventListener('show.bs.modal', function (event) {

            const button = event.relatedTarget;

            const id = button.getAttribute("data-id");
            const name = button.getAttribute("data-name");

            document.getElementById("catName").textContent = name;

            const confirmBtn = document.getElementById("confirmDelete");

            confirmBtn.onclick = function () {
                this.innerHTML = "Deleting...";
                this.disabled = true;

                window.location.href = `/Category/Delete/${id}`;
            };
        });
    </script>
}