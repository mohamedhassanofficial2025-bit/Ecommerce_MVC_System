<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplicationV02</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplicationV02.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --dashboard-bg: #f8fafc;
            --sidebar-bg: #ffffff;
            --sidebar-border: #f1f5f9;
            --sidebar-link-hover: #f1f5f9;
            --sidebar-link-active: #f1f5f9;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --accent-primary: #0f172a;
            --accent-success: #10b981;
            --accent-danger: #ef4444;
            --glass-bg: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(241, 245, 249, 0.6);
            --radius-lg: 16px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --shadow-subtle: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.05);
            --shadow-premium: 0 4px 6px -1px rgba(0, 0, 0, 0.03), 0 2px 4px -2px rgba(0, 0, 0, 0.03), 0 12px 16px -4px rgba(0, 0, 0, 0.04);
            --transition-smooth: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            background-color: var(--dashboard-bg);
            color: var(--text-main);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            letter-spacing: -0.011em;
            overflow-x: hidden;
        }

        /* App Shell Layout */
        .app-shell {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* Sidebar Navigation Component */
        .app-sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--sidebar-border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 1030;
            transition: var(--transition-smooth);
        }

        .sidebar-brand-wrapper {
            height: 70px;
            display: flex;
            align-items: center;
            padding: 0 24px;
            border-bottom: 1px solid var(--sidebar-border);
        }

        .sidebar-brand {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--text-main);
            text-decoration: none;
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-brand i {
            font-size: 1.25rem;
            background: linear-gradient(135deg, #0f172a 0%, #334155 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sidebar-menu {
            list-style: none;
            padding: 24px 16px;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 4px;
            flex-grow: 1;
            overflow-y: auto;
        }

        .sidebar-item-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            padding: 12px 12px 6px 12px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            color: var(--text-muted);
            font-size: 0.925rem;
            font-weight: 500;
            text-decoration: none;
            border-radius: var(--radius-sm);
            transition: var(--transition-smooth);
        }

        .sidebar-link:hover {
            background-color: var(--sidebar-link-hover);
            color: var(--text-main);
        }

        .sidebar-link.active {
            background-color: var(--sidebar-link-active);
            color: var(--text-main);
            font-weight: 600;
        }

        /* Container Layout Contexts */
        .app-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            margin-left: 260px;
            transition: var(--transition-smooth);
        }

        /* Clean Fullscreen Layout for Auth Targets */
        .app-container.fullscreen-auth {
            margin-left: 0 !important;
            background-color: #ffffff;
            justify-content: center;
        }

        /* Top Bar Control Header */
        .app-header {
            height: 70px;
            background-color: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--glass-border);
            position: sticky;
            top: 0;
            z-index: 1020;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-profile-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            background-color: #f1f5f9;
            border-radius: 100px;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-main);
        }

        /* Main Content Viewports */
        .app-main {
            flex: 1;
            padding: 32px;
            display: flex;
            flex-direction: column;
        }

        .app-main.auth-main-layout {
            padding: 0;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle at 100% 0%, rgba(241, 245, 249, 1) 0%, rgba(255, 255, 255, 1) 70%);
        }

        .app-footer {
            padding: 20px 32px;
            background-color: var(--sidebar-bg);
            border-top: 1px solid var(--sidebar-border);
            font-size: 0.825rem;
            color: var(--text-muted);
        }

        /* Premium Shared Global Typography Elements */
        .btn-premium-primary {
            background-color: var(--accent-primary);
            color: #ffffff;
            font-weight: 500;
            font-size: 0.875rem;
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            border: 1px solid transparent;
            box-shadow: var(--shadow-subtle);
            transition: var(--transition-smooth);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-premium-primary:hover {
            background-color: #1e293b;
            color: #ffffff;
            transform: translateY(-0.5px);
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
        }

        .btn-premium-outline {
            background-color: #ffffff;
            color: var(--text-main);
            font-weight: 500;
            font-size: 0.875rem;
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            border: 1px solid #e2e8f0;
            box-shadow: var(--shadow-subtle);
            transition: var(--transition-smooth);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-premium-outline:hover {
            background-color: #f8fafc;
            color: var(--text-main);
            border-color: #cbd5e1;
        }

        .btn-premium-danger {
            background-color: #fef2f2;
            color: var(--accent-danger);
            font-weight: 500;
            font-size: 0.875rem;
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            border: 1px solid #fee2e2;
            transition: var(--transition-smooth);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-premium-danger:hover {
            background-color: var(--accent-danger);
            color: #ffffff;
            border-color: var(--accent-danger);
        }

        .sidebar-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--text-main);
            cursor: pointer;
            padding: 0;
        }

        @@media (max-width: 991.98px) {
            .app-sidebar {
                transform: translateX(-100%);
            }
            .app-sidebar.show {
                transform: translateX(0);
            }
            .app-container {
                margin-left: 0;
            }
            .sidebar-toggle {
                display: block;
            }
            .app-header {
                padding: 0 20px;
            }
            .app-main {
                padding: 24px 20px;
            }
        }
    </style>
</head>
<body class="h-100">

    @{
        // Determine architectural layout variant using context routing descriptors
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        bool isAuthPage = string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase);
    }

    <div class="app-shell">
        
        @if (!isAuthPage)
        {
            <aside class="app-sidebar" id="appSidebar">
                <div class="sidebar-brand-wrapper">
                    <a class="sidebar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-layers-half"></i>
                        <span>AppWorkspace</span>
                    </a>
                </div>
                
                <ul class="sidebar-menu">
                    <li class="sidebar-item-label">Core Viewport</li>
                    <li>
                        <a class="sidebar-link" id="nav-home" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2-fill"></i>
                            <span>Dashboard Overview</span>
                        </a>
                    </li>
                    <li>
                        <a class="sidebar-link" id="nav-privacy" asp-area="" asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-shield-lock-fill"></i>
                            <span>Privacy & Security</span>
                        </a>
                    </li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="sidebar-item-label mt-3">Administration Scope</li>
                        <li>
                            <a class="sidebar-link" id="nav-roles" asp-area="" asp-controller="RoleManager" asp-action="Index">
                                <i class="bi bi-sliders"></i>
                               <span>Role Management</span>
                            </a>
                        </li>
                    }
                </ul>
            </aside>
        }

        <div class="app-container @(isAuthPage ? "fullscreen-auth" : "")">
            
            @if (!isAuthPage)
            {
                <header class="app-header">
                    <div class="d-flex align-items-center gap-3">
                        <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Toggle Side Drawer Menu">
                            <i class="bi bi-list"></i>
                        </button>
                        <span class="text-muted d-none d-md-inline fw-medium fs-7">System Management Platform</span>
                    </div>

                    <div class="header-actions">
                        <ul class="navbar-nav flex-row align-items-center gap-2 m-0 p-0">
                            @if (!User.Identity!.IsAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="btn-premium-outline" asp-controller="Account" asp-action="Login">
                                        <i class="bi bi-box-arrow-in-right"></i>
                                        <span>Sign In</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn-premium-primary" asp-controller="Account" asp-action="Register">
                                        <i class="bi bi-person-plus"></i>
                                        <span>Create Account</span>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item me-2">
                                    <div class="user-profile-badge">
                                        <i class="bi bi-person-circle text-dark"></i>
                                        <span>@User.Identity.Name</span>
                                    </div>
                                </li>
                                <li class="nav-item">
                                    <a class="btn-premium-danger" asp-controller="Account" asp-action="LogOut">
                                        <i class="bi bi-box-arrow-right"></i>
                                        <span>Log Out</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </header>
            }

            <main role="main" class="app-main @(isAuthPage ? "auth-main-layout" : "")">
                @RenderBody()
            </main>

            @if (!isAuthPage)
            {
                <footer class="app-footer">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                        <div>
                            &copy; 2026 - <span class="fw-semibold text-dark">WebApplicationV02 Platform</span>.
                        </div>
                        <div class="d-flex gap-3">
                            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted hover-dark">Privacy Framework Policy</a>
                        </div>
                    </div>
                </footer>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebarToggle = document.getElementById('sidebarToggle');
            const appSidebar = document.getElementById('appSidebar');

            if (sidebarToggle && appSidebar) {
                sidebarToggle.addEventListener('click', function (e) {
                    e.stopPropagation();
                    appSidebar.classList.toggle('show');
                });

                document.addEventListener('click', function (e) {
                    if (window.innerWidth <= 991.98 && 
                        !appSidebar.contains(e.target) && 
                        e.target !== sidebarToggle && 
                        !sidebarToggle.contains(e.target)) {
                        appSidebar.classList.remove('show');
                    }
                });
            }

            const currentPath = window.location.pathname.toLowerCase();
            const homeLink = document.getElementById('nav-home');
            const privacyLink = document.getElementById('nav-privacy');
            const rolesLink = document.getElementById('nav-roles');

            if (currentPath === '/' || currentPath.includes('/home/index')) {
                if(homeLink) homeLink.classList.add('active');
            } else if (currentPath.includes('/privacy')) {
                if(privacyLink) privacyLink.classList.add('active');
            } else if (currentPath.includes('/rolemanager')) {
                if(rolesLink) rolesLink.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>