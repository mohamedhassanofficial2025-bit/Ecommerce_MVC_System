@model ProductReadVM

@{
    ViewData["Title"] = Model.ProdTitle;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12">
            <div class="product-card">
                
                <div class="product-image-side">
                    <div class="product-badge">
                        <i class="bi bi-box-seam"></i>
                        <span>System Asset Inventory</span>
                    </div>
                    <img src="~/Images/Products/@Model.ImageURL" alt="@Model.ProdTitle" class="product-image" />
                </div>

                <div class="product-content-side d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                            <div>
                                <span class="product-category text-uppercase tracking-wider">@Model.ProdCategory</span>
                                <h1 class="product-title mt-3">@Model.ProdTitle</h1>
                                <div class="product-meta">
                                    <span><i class="bi bi-fingerprint"></i> ID Ref: @Model.ProdId</span>
                                    <span><i class="bi bi-calendar-check"></i> Expiration: @Model.ExpiryDate.ToString("yyyy-MM-dd")</span>
                                </div>
                            </div>
                            <div class="price-box border border-light-subtle shadow-sm">
                                <span class="price-label fw-semibold uppercase tracking-wider d-block">System Valuation</span>
                                <h2 class="price-value">$@Model.ProdPrice.ToString("F2")</h2>
                            </div>
                        </div>

                        <div class="content-section pt-2">
                            <h5 class="section-title text-muted text-uppercase fs-7 tracking-wider">Product Synopsis</h5>
                            <p class="description-text">@Model.ProdDescription</p>
                        </div>

                        <div class="stats-grid">
                            <div class="stat-card border border-light-subtle">
                                <div class="stat-icon bg-primary-subtle text-primary">
                                    <i class="bi bi-boxes"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block text-uppercase tracking-wider fs-8">Current Balance</small>
                                    <h5 class="mb-0 fw-bold text-dark">@Model.ProdCount Counted Units</h5>
                                </div>
                            </div>
                            <div class="stat-card border border-light-subtle">
                                <div class="stat-icon @(Model.ProdCount > 5 ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                    <i class="bi bi-shield-check-fill"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block text-uppercase tracking-wider fs-8">Safety Index Status</small>
                                    <h5 class="mb-0 fw-bold @(Model.ProdCount > 5 ? "text-success" : "text-danger")">
                                        @(Model.ProdCount > 5 ? "Sufficient Supply" : "Critically Low Stock")
                                    </h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="product-actions border-top border-light-subtle pt-4">
                        <a href="/Product/Index" class="btn btn-premium-outline px-4">
                            <i class="bi bi-arrow-left"></i> Back to Ledger
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-2">
                                <a href="/Product/Edit/@Model.ProdId" class="btn btn-premium-outline text-warning border-warning-subtle px-4">
                                    <i class="bi bi-pencil-square"></i> Modify Context
                                </a>
                                <button class="btn btn-premium-danger px-4" id="deleteBtn" data-id="@Model.ProdId">
                                    <i class="bi bi-trash3-fill"></i> De-allocate Asset
                                </button>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="DeleteModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-premium">
            <div class="modal-body p-5 text-center">
                <div class="delete-icon mb-4 shadow-sm">
                    <i class="bi bi-trash3-fill text-danger"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">De-allocate Asset?</h3>
                <p class="text-muted px-3 mb-4">You are about to wipe this record out of the persistent storage infrastructure layers. This configuration step cannot be undone.</p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-premium-outline px-4" data-bs-dismiss="modal">Retain Asset</button>
                    <button type="button" class="btn btn-danger px-4 text-white border-0" id="confirmDelete">Confirm Wipeout</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const deleteBtn = document.getElementById("deleteBtn");
            const modalElement = document.getElementById("DeleteModal");

            if (deleteBtn && modalElement) {
                const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
                let targetedAssetId = null;

                deleteBtn.addEventListener("click", function () {
                    targetedAssetId = this.getAttribute("data-id");
                    modalInstance.show();
                });

                document.getElementById("confirmDelete").addEventListener("click", function () {
                    window.location.href = `/Product/Delete/${targetedAssetId}`;
                });
            }
        });
    </script>
}