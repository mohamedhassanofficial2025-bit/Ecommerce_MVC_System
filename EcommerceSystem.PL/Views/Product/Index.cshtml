@model List<ProductReadVM>

@{
    ViewData["Title"] = "Products Portal Dashboard";
}

<style>
    .dashboard-header-block {
        margin-bottom: 32px;
        animation: tableFadeIn 0.3s ease-out;
    }
    
    .portal-table-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -2px rgba(0, 0, 0, 0.02);
        overflow: hidden;
    }

    .custom-table thead {
        background-color: #0f172a;
        color: #ffffff;
    }

    .custom-table th {
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 16px 24px;
        border: none;
    }

    .custom-table td {
        padding: 18px 24px;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
    }

    .product-thumbnail-frame {
        width: 56px;
        height: 56px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background-color: #f8fafc;
    }

    .badge-premium {
        font-weight: 600;
        font-size: 0.775rem;
        padding: 6px 12px;
        border-radius: 6px;
    }

    @@keyframes tableFadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="container-fluid px-4 py-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-sm-items-center gap-3 dashboard-header-block">
        <div>
            <h1 class="h2 fw-bold text-dark m-0">Products Ledger</h1>
            <p class="text-muted m-0 fs-7">Audit real-time catalog variations, stock allocations, and product life cycles.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" asp-controller="Home" class="btn btn-premium-outline">
                <i class="bi bi-house-door me-1"></i> Home
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" asp-controller="Product" class="btn btn-premium-primary">
                    <i class="bi bi-plus-lg me-1"></i> Add Product
                </a>
            }
        </div>
    </div>

    <div class="portal-table-card">
        <div class="table-responsive">
            <table class="table custom-table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th style="width: 100px;">Asset</th>
                        <th>Product Context Details</th>
                        <th>Category</th>
                        <th>Valuation Price</th>
                        <th>Expiration Target</th>
                        <th>Stock Units</th>
                        <th class="text-end" style="width: 200px;">Control Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="text-muted fw-mono fs-7">#@p.ProdId</td>
                            <td>
                                <img src="~/Images/Products/@p.ImageURL" class="product-thumbnail-frame" alt="Product thumbnail" />
                            </td>
                            <td>
                                <div class="fw-semibold text-dark fs-6">@p.ProdTitle</div>
                                <div class="text-muted fs-7 text-truncate" style="max-width: 340px;">@p.ProdDescription</div>
                            </td>
                            <td>
                                <span class="badge badge-premium bg-light text-dark border border-light-subtle">@p.ProdCategory</span>
                            </td>
                            <td>
                                <span class="badge badge-premium bg-success-subtle text-success">$@p.ProdPrice.ToString("F2")</span>
                            </td>
                            <td>
                                <span class="badge badge-premium bg-secondary-subtle text-secondary fw-medium">
                                    <i class="bi bi-calendar3 me-1"></i>@p.ExpiryDate.ToString("yyyy-MM-dd")
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-premium @(p.ProdCount > 5 ? "bg-primary-subtle text-primary" : "bg-danger-subtle text-danger")">
                                    @p.ProdCount Units
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a href="/Product/Details/@p.ProdId" class="btn btn-sm btn-premium-outline px-2 py-1 fs-7">
                                        View
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a href="/Product/Edit/@p.ProdId" class="btn btn-sm btn-premium-outline px-2 py-1 fs-7 text-warning">
                                            Edit
                                        </a>
                                        <button class="btn btn-sm btn-premium-danger px-2 py-1 fs-7 deleteBtn"
                                                data-id="@p.ProdId"
                                                data-name="@p.ProdTitle"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal">
                                            Delete
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-premium rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-danger d-flex align-items-center gap-2" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle-fill"></i> Confirm Deletion
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-3 text-start">
                <p class="text-muted m-0">Are you sure you want to permanently erase this product profile? This item will be cleared from inventory tracking metrics.</p>
                <div class="p-3 bg-light rounded-3 mt-3 border border-light-subtle">
                    <span class="fs-7 text-muted d-block uppercase fw-bold tracking-wider">Target Profile</span>
                    <h5 class="fw-bold text-dark m-0 mt-1" id="productName"></h5>
                </div>
            </div>
            <div class="modal-footer border-0 pb-4 px-4 justify-content-end gap-2">
                <button type="button" class="btn btn-premium-outline" data-bs-dismiss="modal">Cancel</button>
                <a id="confirmDeleteBtn" class="btn btn-danger px-4 fw-medium text-white border-0">Execute Erase</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const deleteButtons = document.querySelectorAll(".deleteBtn");
            const confirmBtn = document.getElementById("confirmDeleteBtn");
            const productNameField = document.getElementById("productName");

            deleteButtons.forEach(btn => {
                btn.addEventListener("click", function () {
                    const targetId = this.getAttribute("data-id");
                    const targetName = this.getAttribute("data-name");

                    productNameField.innerText = targetName;
                    confirmBtn.href = `/Product/Delete/${targetId}`;
                });
            });
        });
    </script>
}