@model List<ProductReadVM>

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-primary">Products Dashboard</h2>
            <small class="text-muted">Manage all your products</small>
        </div>

        <div class="d-flex gap-2">

            <a asp-action="Index" asp-controller="Home" class="btn btn-outline-dark">
                🏠 Home
            </a>

            @if(User.IsInRole("Admin"))
            {
                <a asp-action="Create" asp-controller="Product" class="btn btn-primary">
                    + Add Product
                </a>
            }

        </div>

    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="bg-dark text-white">
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>Price</th>
                            <th>ExpiryDate</th>
                            <th>Stock</th>
                            <th>Category</th>
                            <th>Image</th> 
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var p in Model)
                        {
                            <tr>

                                <td>@p.ProdId</td>

                                <td>
                                    <div class="fw-semibold">@p.ProdTitle</div>
                                    <small class="text-muted">@p.ProdDescription</small>
                                </td>

                                <td>
                                    <span class="badge bg-success px-3 py-2">
                                        $@p.ProdPrice
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-success px-3 py-2">
                                        @p.ExpiryDate
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(p.ProdCount > 5 ? "bg-primary" : "bg-danger") px-3 py-2">
                                        @p.ProdCount
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-secondary px-3 py-2">
                                        @p.ProdCategory
                                    </span>
                                </td>
                                <th scope="row">
                                    <img src="~/Images/Products/@p.ImageURL" class="img-thumbnail" style="width: 100px; height: 100px;" />
                                </th>
                                <td class="text-center">

                                    <a href="/Product/Details/@p.ProdId"
                                           class="btn btn-sm btn-outline-info">
                                        View
                                    </a>

                                    @if(User.IsInRole("Admin"))
                                    {
                                        <a href="/Product/Edit/@p.ProdId"
                                               class="btn btn-sm btn-outline-warning">
                                            Edit
                                        </a>

                                        <button class="btn btn-sm btn-outline-danger deleteBtn"
                                                data-id="@p.ProdId"
                                                data-name="@p.ProdTitle"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal">
                                            Delete
                                        </button>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- ✅ Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content rounded-4">

            <div class="modal-header">
                <h5 class="modal-title text-danger">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">

                <p class="mb-2">Are you sure you want to delete:</p>

                <h5 class="fw-bold text-dark" id="productName"></h5>

            </div>

            <div class="modal-footer justify-content-center">

                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <a id="confirmDeleteBtn" class="btn btn-danger">
                    Delete
                </a>

            </div>

        </div>

    </div>

</div>

<!-- ✅ Script -->
@section Scripts {

    <script>

        const deleteButtons = document.querySelectorAll(".deleteBtn");

        const confirmBtn = document.getElementById("confirmDeleteBtn");
        const productName = document.getElementById("productName");

        deleteButtons.forEach(btn => {
            btn.addEventListener("click", function () {

                const id = this.getAttribute("data-id");
                const name = this.getAttribute("data-name");

                productName.innerText = name;
                confirmBtn.href = `/Product/Delete/${id}`;
            });
        });

    </script>

}