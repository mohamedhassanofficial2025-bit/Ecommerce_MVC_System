@model ProductCreateVM

@{
    ViewData["Title"] = "Initialize Product Node";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card shadow-premium border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-success p-4 border-0 text-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white text-success rounded-3 px-3 py-2 fw-bold">
                            <i class="bi bi-file-earmark-plus-fill"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">Provision New Inventory Entry</h4>
                            <p class="text-muted m-0 fs-7 text-white-50">Publish a new operational asset definition tracking row token profile node.</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 bg-white">
                    <form asp-action="Create" asp-controller="Product" enctype="multipart/form-data" method="post" class="needs-validation">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="ProdTitle" class="form-label fw-bold text-dark fs-7 text-uppercase">Product Designation Title</label>
                            <input asp-for="ProdTitle" class="form-control form-control-lg border-light-subtle fs-6" placeholder="e.g. High-Performance Enterprise Processor Core" />
                            <span asp-validation-for="ProdTitle" class="text-danger fs-7 mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ProdDescription" class="form-label fw-bold text-dark fs-7 text-uppercase">Descriptive Context Documentation</label>
                            <textarea asp-for="ProdDescription" class="form-control border-light-subtle fs-6" rows="4" placeholder="Provide contextual metadata specifications, warranty indices, and dimension limits..."></textarea>
                            <span asp-validation-for="ProdDescription" class="text-danger fs-7 mt-1 d-block"></span>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-4">
                                <label asp-for="ProdPrice" class="form-label fw-bold text-dark fs-7 text-uppercase">Unit Valuation Price ($)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-light-subtle text-muted">$</span>
                                    <input asp-for="ProdPrice" type="number" step="0.01" class="form-control border-light-subtle" placeholder="0.00" value="" />
                                </div>
                                <span asp-validation-for="ProdPrice" class="text-danger fs-7 mt-1 d-block"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="ProdCount" class="form-label fw-bold text-dark fs-7 text-uppercase">Initial Stock Intake Units</label>
                                <input asp-for="ProdCount" type="number" class="form-control border-light-subtle" placeholder="Quantity volume mapping" value="" />
                                <span asp-validation-for="ProdCount" class="text-danger fs-7 mt-1 d-block"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="ExpiryDate" class="form-label fw-bold text-dark fs-7 text-uppercase">Expiration Target Timeline</label>
                                <input asp-for="ExpiryDate" type="date" class="form-control border-light-subtle" value="@DateTime.Now.AddYears(1).ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="ExpiryDate" class="text-danger fs-7 mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="mb-4 p-4 bg-light rounded-4 border border-light-subtle">
                            <label asp-for="Image" class="form-label fw-bold text-dark fs-7 text-uppercase">Product Representation Image Binary Asset</label>
                            <input asp-for="Image" type="file" class="form-control border-light-subtle bg-white" />
                            <span asp-validation-for="Image" class="text-danger fs-7 mt-1 d-block"></span>
                            <small class="text-muted fs-8 d-block mt-1">Permissible files extensions definitions: .png, .jpg, .jpeg, .webp format types.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark fs-7 text-uppercase">Structural Catalog Categorization Scope</label>
                            <select name="CategoryId" class="form-select border-light-subtle">
                                <option value="" disabled selected>-- Select Categorization Node Scope Assignment --</option>
                                @foreach (var p in Model.Categories)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                        </div>

                        <div class="d-flex justify-content-between align-items-center border-top border-light-subtle pt-4 mt-5">
                            <a asp-action="Index" asp-controller="Product" class="btn btn-premium-outline px-4">Cancel</a>
                            <button type="submit" class="btn btn-success text-white border-0 px-5 fw-bold">Publish Node Definition</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}